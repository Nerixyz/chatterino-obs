include_guard(GLOBAL)

if(CMAKE_VS_PLATFORM_NAME)
  set(WIN_TARGET_ARCH "${CMAKE_VS_PLATFORM_NAME}")
elseif(CMAKE_SYSTEM_PROCESSOR STREQUAL "arm64" OR CMAKE_SYSTEM_PROCESSOR STREQUAL "ARM64")
  set(WIN_TARGET_ARCH "arm64")
elseif(CMAKE_SYSTEM_PROCESSOR MATCHES "arm*")
  set(WIN_TARGET_ARCH "arm")
elseif(CMAKE_SIZEOF_VOID_P EQUAL 8)
  set(WIN_TARGET_ARCH "x64")
elseif(CMAKE_SIZEOF_VOID_P EQUAL 4)
  set(WIN_TARGET_ARCH "x86")
endif()
